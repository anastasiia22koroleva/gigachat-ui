# Учётные данные GigaChat (https://developers.sber.ru/gigachat)
# Проще всего: в приложении откройте «Параметры» и вставьте ключ — он
# сохранится в localStorage этого браузера.
#
# Вариант 1: одна строка Base64 (ключ авторизации из кабинета)
# REACT_APP_GIGACHAT_CREDENTIALS=

# Вариант 2: отдельно id и secret
# REACT_APP_GIGACHAT_CLIENT_ID=
# REACT_APP_GIGACHAT_CLIENT_SECRET=

# Опционально: базовые URL, если настроен свой прокси (production)
# REACT_APP_GIGACHAT_API_BASE=/gigachat-api
# REACT_APP_GIGACHAT_OAUTH_BASE=/gigachat-oauth
